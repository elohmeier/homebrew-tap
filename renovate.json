{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "mode": "full",
  "dependencyDashboardApproval": false,
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "ignoreTests": false,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Homebrew formulae: GitHub releases (v-prefixed tags)",
      "fileMatch": ["^Formula/.+\\.rb$"],
      "matchStrings": [
        "url \"https://github\\.com/(?<depName>[^/]+/[^/]+)/releases/download/v(?<currentValue>[^/]+)/"
      ],
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Homebrew formulae: GitHub archive tags (v-prefixed)",
      "fileMatch": ["^Formula/.+\\.rb$"],
      "matchStrings": [
        "url \"https://github\\.com/(?<depName>[^/]+/[^/]+)/archive/refs/tags/v(?<currentValue>[^\"]+)\\.tar\\.gz\""
      ],
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Homebrew formulae: GitHub releases (no v prefix)",
      "fileMatch": ["^Formula/ssh-to-age\\.rb$"],
      "matchStrings": [
        "url \"https://github\\.com/(?<depName>[^/]+/[^/]+)/releases/download/(?<currentValue>[^/]+)/"
      ],
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "description": "Do not automerge major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
